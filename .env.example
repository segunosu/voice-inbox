# Voice Inbox configuration — NAMES ONLY, no real values (see SECURITY.md).
# Real values live in C:\Users\Oem\.secrets\voice-inbox.env on the dev machine.

# Database / Supabase
DATABASE_URL=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server contexts only, never in clients
SUPABASE_STORAGE_BUCKET=voice-inbox-audio

# AI providers
OPENAI_API_KEY=                     # transcription
ANTHROPIC_API_KEY=                  # structuring + routing adjudication

# Eventing / webhooks
WEBHOOK_SIGNING_SECRET=

# Notifications
FCM_SERVICE_ACCOUNT_REFERENCE=      # path/reference, not the JSON itself

# Runner
RUNNER_API_TOKEN=
PUBLIC_API_BASE_URL=
